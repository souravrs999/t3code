{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "T3 Code",
  "version": "0.0.4-alpha.1",
  "identifier": "com.t3tools.t3code",
  "build": {
    "devUrl": "http://localhost:5733",
    "frontendDist": "../../apps/web/dist",
    "beforeDevCommand": "cd web && bun run dev",
    "beforeBuildCommand": "cd web && bun run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "T3 Code",
        "width": 1100,
        "height": 780,
        "minWidth": 840,
        "minHeight": 620,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "visible": false,
        "trafficLightPosition": { "x": 16, "y": 26 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true
    }
  },
  "plugins": {}
}
